{
    "name": "orange/orange-framework",
    "authors": [
        {
            "name": "Don Myers",
            "email": "donmyers@me.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "application\\": "application",
            "api\\":"api"
        },
        "files": [],
        "classmap": []
    },
    "require-dev": {
        "phpunit/phpunit": "^13.2",
        "phpunit/php-code-coverage": "^14.2",
        "squizlabs/php_codesniffer": "3.*",
        "phpstan/phpstan": "^2.2",
        "infection/infection": "^0.34",
        "phpmd/phpmd": "^2.15",
        "rector/rector": "^2.0",
        "deptrac/deptrac": "^4.0"
    },
    "require": {
        "nesbot/carbon": "3.8.4",
        "monolog/monolog": "3.*",
        "michelf/php-markdown": "2.*",
        "zordius/lightncandy": "1.*",
        "brick/varexporter": "0.*",
        "orange/framework": "dev-main",
        "orange/cookies": "dev-master",
        "orange/files": "dev-master",
        "orange/request": "dev-master"
    },
    "scripts": {
        "test": "cd unittest && sh runUnitTests.sh",
        "test:orange": "cd vendor/orange/framework/unittest && sh runUnitTests.sh",
        "test:orangeCoverage": "cd vendor/orange/framework/unittest && sh runCoverage.sh",
        "type-check": "phpstan analyse",
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "rector": "rector --dry-run",
        "rector:fix": "rector"
    },
    "scripts-descriptions": {
        "test:orange": "Run the Orange Framework core unit tests.",
        "test:orangeCoverage": "Run the Orange Framework core unit tests with code coverage.",
        "type-check": "Run PHPStan static type analysis on the application code.",
        "lint": "Check the application code against the PSR-12 coding standard.",
        "lint:fix": "Auto-fix PSR-12 coding standard violations where possible.",
        "rector": "Preview Rector automated refactorings (dry-run, writes nothing).",
        "rector:fix": "Apply Rector automated refactorings to the application code."
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://projectorangebox.github.io/OrangePackages/"
        }
    ],
    "config": {
        "allow-plugins": {
            "infection/extension-installer": true
        }
    }
}
