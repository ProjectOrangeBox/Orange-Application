; ###########################################################################
; IMPORTANT: the generated .env must contain NO comment lines.
;
; Two parsers read .env and they disagree about comments:
;   - PHP's parse_ini_file() wants ";" and chokes on "#"
;   - Docker Compose auto-loads .env, wants "#", and chokes on ";"
; There is no comment style both accept, so .env carries values only and all
; documentation lives here instead. docker-entrypoint.sh strips these comment
; lines when it seeds .env from this file. If you add options to .env by hand,
; add them without comments.
; ###########################################################################

; ---------------------------------------------------------------------------
; Application environment
; ---------------------------------------------------------------------------
; Also selects how the container serves the app. docker-entrypoint.sh reads
; this at startup, so a change only takes effect on container restart:
;
;   production -> FrankenPHP worker mode. The app is booted once and stays
;                 resident between requests (fast). Code is held in memory,
;                 so edits are NOT picked up until you restart the container -
;                 which is also how you deploy.
;
;   anything   -> FrankenPHP classic mode. PHP is re-read from disk on every
;   else          request, exactly like the old Apache setup, so edits show up
;                 immediately on reload.
;
; Left unset this defaults to production, matching the framework's own default.
ENVIRONMENT=development
DEBUG=true

; ---------------------------------------------------------------------------
; Container / web server options (read by docker-entrypoint.sh on startup)
; ---------------------------------------------------------------------------
; These must stay above the first [section] header - the entrypoint only reads
; top-level keys, so anything below a section header is invisible to it.

; Hostname Caddy binds to, and the name on the TLS certificate.
;   localhost     -> HTTPS with a local self-signed cert (browser warning)
;   :80           -> plain HTTP only, no TLS at all
;   www.site.com  -> automatic Let's Encrypt certificate (production)
; The container listens on 80/443; docker-compose.yml maps those to 8080/8443.
SERVER_NAME=localhost

; Worker mode only (ENVIRONMENT=production). Recycles each worker process
; after this many requests, bounding any slow memory leak in a long-lived
; service. 0 disables the limit. Ignored in classic mode.
MAX_REQUESTS=0

; ---------------------------------------------------------------------------
; Database
; ---------------------------------------------------------------------------
[db]
; use host.docker.internal when the app runs in its container,
; 127.0.0.1 when running on the host
host = 'host.docker.internal'
port = 3306
database = webapp
username = webapp
password = webapp_password
charset = utf8mb4
