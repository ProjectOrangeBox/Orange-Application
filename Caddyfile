{
	{$CADDY_GLOBAL_OPTIONS}

	frankenphp {
		# docker-entrypoint.sh sets FRANKENPHP_CONFIG to "worker ..." when
		# ENVIRONMENT=production in .env, and leaves it empty otherwise.
		# Empty means classic mode: PHP is re-read from disk every request.
		{$FRANKENPHP_CONFIG}
	}
}

{$CADDY_EXTRA_CONFIG}

# Built by the entrypoint from SERVER_NAME in .env. In production this is just
# the hostname (automatic Let's Encrypt cert, HTTP redirects to HTTPS). In
# development it is expanded to an explicit "http://host, https://host" pair so
# both published ports work - see docker-entrypoint.sh for why.
{$CADDY_SITE_ADDRESS:localhost} {
	log {
		{$CADDY_SERVER_LOG_OPTIONS}
	}

	root {$SERVER_ROOT:/var/www/html/htdocs}

	encode zstd br gzip

	# Serves static files directly and routes everything else to index.php,
	# replacing the old htdocs/.htaccess rewrite. Dotfiles are hidden.
	php_server
}
